# Anthropic API key (required for LLM-generated files: edit.js, save.js, view.js)
NUXT_ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-sonnet-4-20250514)
NUXT_CLAUDE_MODEL=claude-sonnet-4-20250514

# Max tokens for Claude response (default: 8000)
NUXT_CLAUDE_MAX_TOKENS=8000

# Directory for temporary zip bundles (default: ./.bundles)
NUXT_BUNDLE_DIR=./.bundles

# Bundle TTL in milliseconds before cleanup (default: 3600000 = 1 hour)
NUXT_BUNDLE_TTL_MS=3600000
